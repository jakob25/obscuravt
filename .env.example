# Supabase — get these from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session — generate with: openssl rand -base64 32
SESSION_SECRET=your-random-32-char-secret-here
# Admin usernames (comma-separated)
ADMIN_USERNAMES=jakob25,admin

# Twitch API — create app at https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_ACCESS_TOKEN=your_twitch_access_token_here

# YouTube Data API v3 — get key from Google Cloud Console
YOUTUBE_API_KEY=your_youtube_api_key_here