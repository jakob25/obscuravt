'use client'

import { useState } from 'react'
import { useAuth } from '@/lib/auth-context'
import { supabase } from '@/lib/supabase'
import { Search, Plus, ThumbsUp, ExternalLink } from 'lucide-react'
import Link from 'next/link'

interface PendingVTuber {
  id: string
  name: string
  handle: string
  platform: string
  link: string
  bio: string
  nominated_by: string
  nomination_count: number
  user_voted: boolean
}

export default function NominatePage() {
  const { user } = useAuth()
  const [pending, setPending] = useState<PendingVTuber[]>([])
  const [loaded, setLoaded] = useState(false)
  const [loading, setLoading] = useState(false)
  const [submitting, setSubmitting] = useState(false)
  const [voting, setVoting] = useState<string | null>(null)
  const [error, setError] = useState('')
  const [success, setSuccess] = useState('')

  // Form state
  const [name, setName] = useState('')
  const [handle, setHandle] = useState('')
  const [platform, setPlatform] = useState('youtube')
  const [link, setLink] = useState('')
  const [bio, setBio] = useState('')

  const loadPending = async () => {
    setLoading(true)
    const { data: vtubers } = await supabase
      .from('vtubers')
      .select('id, name, handle, platform, link, bio, nominated_by')
      .eq('approved', false)
      .order('created_at', { ascending: false })

    const { data: nominations } = await supabase
      .from('vtuber_nominations')
      .select('vtuber_id, profile_id')

    const nomCount: Record<string, number> = {}
    const userVoted = new Set<string>()
    for (const n of nominations ?? []) {
      nomCount[n.vtuber_id] = (nomCount[n.vtuber_id] ?? 0) + 1
      if (user && n.profile_id === user.username) userVoted.add(n.vtuber_id)
    }

    setPending((vtubers ?? []).map(v => ({
      ...v,
      nomination_count: nomCount[v.id] ?? 0,
      user_voted: userVoted.has(v.id),
    })))
    setLoaded(true)
    setLoading(false)
  }

  const submitNomination = async (e: React.FormEvent) => {
    e.preventDefault()
    if (!user) return
    setSubmitting(true)
    setError('')

    // Check for duplicate
    const { data: existing } = await supabase
      .from('vtubers')
      .select('id')
      .ilike('handle', handle)
      .single()

    if (existing) {
      setError('This VTuber has already been nominated or is already in the Vault.')
      setSubmitting(false)
      return
    }

    const id = `vt_${handle.toLowerCase().replace(/[^a-z0-9]/g, '')}_${Date.now()}`

    const { error: insertErr } = await supabase.from('vtubers').insert({
      id,
      name,
      handle,
      platform,
      link,
      bio,
      tags: [],
      approved: false,
      nominated_by: user.username,
      created_at: new Date().toISOString(),
    })

    if (insertErr) {
      setError(insertErr.message)
      setSubmitting(false)
      return
    }

    // Auto-vote for your own nomination
    await supabase.from('vtuber_nominations').insert({
      vtuber_id: id,
      profile_id: user.username,
      username: user.username,
    })

    setSuccess(`${name} has been nominated! Share their profile to get more votes.`)
    setName(''); setHandle(''); setLink(''); setBio('')
    setSubmitting(false)
    if (loaded) loadPending()
  }

  const voteNomination = async (vtuberId: string, currentlyVoted: boolean) => {
    if (!user || voting) return
    setVoting(vtuberId)

    if (currentlyVoted) {
      await supabase.from('vtuber_nominations')
        .delete()
        .eq('vtuber_id', vtuberId)
        .eq('profile_id', user.username)
    } else {
      await supabase.from('vtuber_nominations').insert({
        vtuber_id: vtuberId,
        profile_id: user.username,
        username: user.username,
      })
    }

    setPending(p => p.map(v => v.id === vtuberId ? {
      ...v,
      nomination_count: v.nomination_count + (currentlyVoted ? -1 : 1),
      user_voted: !currentlyVoted,
    } : v))

    setVoting(null)
  }

  return (
    <div className="container mx-auto px-4 py-8 max-w-2xl">
      <div className="mb-8">
        <h1 className="text-2xl font-bold text-vault-cream mb-1">Nominate a VTuber</h1>
        <p className="text-muted-foreground text-sm">
          Know a hidden gem? Nominate them. Once they get 10 community votes they're automatically added to the Vault.
        </p>
      </div>

      {/* Nomination form */}
      {user ? (
        <div className="vault-card rounded-2xl p-6 mb-8">
          <h2 className="font-semibold text-vault-cream mb-4 flex items-center gap-2">
            <Plus className="h-4 w-4 text-vault-gold" />
            Submit a nomination
          </h2>
          {success && (
            <div className="mb-4 p-3 rounded-lg bg-green-500/10 border border-green-500/30 text-green-400 text-sm">
              {success}
            </div>
          )}
          {error && (
            <div className="mb-4 p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 text-sm">
              {error}
            </div>
          )}
          <form onSubmit={submitNomination} className="space-y-3">
            <input
              value={name}
              onChange={e => setName(e.target.value)}
              placeholder="VTuber name"
              required
              className="w-full h-10 px-3 rounded-lg bg-muted/30 border border-border text-vault-cream text-sm placeholder:text-muted-foreground focus:outline-none focus:border-vault-bronze/60"
            />
            <input
              value={handle}
              onChange={e => setHandle(e.target.value)}
              placeholder="Handle / username"
              required
              className="w-full h-10 px-3 rounded-lg bg-muted/30 border border-border text-vault-cream text-sm placeholder:text-muted-foreground focus:outline-none focus:border-vault-bronze/60"
            />
            <select
              value={platform}
              onChange={e => setPlatform(e.target.value)}
              className="w-full h-10 px-3 rounded-lg bg-muted/30 border border-border text-vault-cream text-sm focus:outline-none focus:border-vault-bronze/60"
            >
              <option value="youtube">YouTube</option>
              <option value="twitch">Twitch</option>
              <option value="other">Other</option>
            </select>
            <input
              value={link}
              onChange={e => setLink(e.target.value)}
              placeholder="Channel / profile link"
              type="url"
              required
              className="w-full h-10 px-3 rounded-lg bg-muted/30 border border-border text-vault-cream text-sm placeholder:text-muted-foreground focus:outline-none focus:border-vault-bronze/60"
            />
            <textarea
              value={bio}
              onChange={e => setBio(e.target.value)}
              placeholder="Why should they be in the Vault? (optional)"
              rows={3}
              className="w-full px-3 py-2 rounded-lg bg-muted/30 border border-border text-vault-cream text-sm placeholder:text-muted-foreground focus:outline-none focus:border-vault-bronze/60 resize-none"
            />
            <button
              type="submit"
              disabled={submitting}
              className="w-full h-10 rounded-lg bg-vault-gold text-vault-deep font-semibold text-sm disabled:opacity-50"
            >
              {submitting ? 'Submitting…' : 'Nominate'}
            </button>
          </form>
        </div>
      ) : (
        <div className="vault-card rounded-2xl p-6 mb-8 text-center">
          <p className="text-muted-foreground text-sm mb-4">Sign in to nominate VTubers.</p>
          <Link href="/login" className="inline-flex items-center justify-center h-10 px-6 rounded-lg bg-vault-gold text-vault-deep font-semibold text-sm">
            Sign In
          </Link>
        </div>
      )}

      {/* Pending nominations */}
      <div>
        <div className="flex items-center justify-between mb-4">
          <h2 className="font-semibold text-vault-cream flex items-center gap-2">
            <Search className="h-4 w-4 text-vault-gold" />
            Pending nominations
          </h2>
          <button
            onClick={loadPending}
            disabled={loading}
            className="text-xs text-vault-gold hover:text-vault-amber disabled:opacity-50"
          >
            {loaded ? 'Refresh' : 'Load'}
          </button>
        </div>

        {!loaded && (
          <p className="text-muted-foreground text-sm text-center py-8">Click load to see pending nominations.</p>
        )}

        {loaded && pending.length === 0 && (
          <p className="text-muted-foreground text-sm text-center py-8">No pending nominations — be the first!</p>
        )}

        <div className="space-y-3">
          {pending.map(vt => (
            <div key={vt.id} className="vault-card rounded-xl p-4 flex items-start gap-4">
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 mb-0.5">
                  <span className="font-semibold text-vault-cream text-sm">{vt.name}</span>
                  <span className="text-[10px] text-muted-foreground capitalize px-1.5 py-0.5 rounded bg-muted/40 border border-border">
                    {vt.platform}
                  </span>
                </div>
                {vt.bio && <p className="text-xs text-muted-foreground line-clamp-2">{vt.bio}</p>}
                <div className="flex items-center gap-3 mt-2">
                  <span className="text-[10px] text-muted-foreground">by {vt.nominated_by}</span>
                  {vt.link && (
                    <a href={vt.link} target="_blank" rel="noopener noreferrer"
                      className="text-[10px] text-vault-gold hover:underline flex items-center gap-0.5">
                      <ExternalLink className="h-2.5 w-2.5" /> View channel
                    </a>
                  )}
                </div>
                {/* Vote progress */}
                <div className="mt-2">
                  <div className="flex items-center justify-between mb-1">
                    <span className="text-[10px] text-muted-foreground">{vt.nomination_count} / 10 votes to approve</span>
                  </div>
                  <div className="h-1 rounded-full bg-muted/40 overflow-hidden">
                    <div
                      className="h-full rounded-full bg-vault-gold transition-all"
                      style={{ width: `${Math.min(vt.nomination_count / 10 * 100, 100)}%` }}
                    />
                  </div>
                </div>
              </div>
              {user && (
                <button
                  onClick={() => voteNomination(vt.id, vt.user_voted)}
                  disabled={voting === vt.id}
                  className={`flex-shrink-0 flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium border transition-all disabled:opacity-50 ${
                    vt.user_voted
                      ? 'bg-vault-gold/20 border-vault-gold/40 text-vault-gold'
                      : 'border-border text-muted-foreground hover:border-vault-bronze/40 hover:text-vault-cream'
                  }`}
                >
                  <ThumbsUp className="h-3.5 w-3.5" />
                  {vt.user_voted ? 'Voted' : 'Vouch'}
                </button>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}
